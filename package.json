    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "papaparse": "^5.5.3",
    "pg": "^8.20.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.58.2"
  }
}
